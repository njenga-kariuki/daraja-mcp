{
  "name": "@daraja-kit/mcp",
  "version": "0.1.0",
  "description": "MCP server for Daraja/M-Pesa integration — scaffold, validate, diagnose, explain",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "daraja-mcp": "dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/http.ts --format esm --clean",
    "dev": "tsup src/index.ts src/http.ts --format esm --watch",
    "start": "node dist/http.js",
    "start:stdio": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@daraja-kit/sdk": "*",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "cors": "^2.8.6",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
