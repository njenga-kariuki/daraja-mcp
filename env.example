# ── Safaricom Daraja — environment ────────────────────────────────────────────
# Get these from https://developer.safaricom.co.ke → My Apps → (your app)
# Copy this file to `.env` and fill in your credentials.
DARAJA_ENV=sandbox                  # sandbox | production
DARAJA_CONSUMER_KEY=
DARAJA_CONSUMER_SECRET=

# ── Lipa Na M-Pesa Online / STK Push ─────────────────────────────────────────
# Sandbox defaults provided; override for production.
MPESA_SHORTCODE=174379
MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919

# ── B2C / Transaction Status / Balance / Reversal ────────────────────────────
# Sandbox initiator defaults:
#   Name: testapi       Password: Safaricom999!*!
MPESA_INITIATOR_NAME=testapi
MPESA_INITIATOR_PASSWORD=Safaricom999!*!
MPESA_B2C_SHORTCODE=600999
MPESA_B2C_SECURITY_CREDENTIAL=       # optional: pre-encrypted credential
MPESA_CERT_PATH=./certs/SandboxCertificate.cer

# ── Callback URL ─────────────────────────────────────────────────────────────
# For sandbox, expose your local server via ngrok / cloudflared and set the
# public URL here. Safaricom must reach this URL.
PUBLIC_BASE_URL=https://example.ngrok-free.app

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000
